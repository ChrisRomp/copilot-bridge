# Mattermost Infrastructure — Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control.

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=mmuser
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=mattermost

# ── Mattermost ──────────────────────────────────────────────
# Docker image tag — see https://hub.docker.com/r/mattermost/mattermost-team-edition/tags
MATTERMOST_IMAGE_TAG=release-11.4

# Site URL — your public URL or http://localhost:8065 for local-only
MM_SITEURL=http://localhost:8065

# Host port to expose Mattermost on
MATTERMOST_PORT=8065

# ── Cloudflare Tunnel (optional) ────────────────────────────
# Only needed if using the 'tunnel' profile:
#   docker compose --profile tunnel up -d
#
# Create a tunnel at: https://one.dash.cloudflare.com → Networks → Tunnels
# Configure the tunnel to route your domain to http://mattermost:8065
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARED_IMAGE_TAG=2025.4.1
